# ==============================================================================
# Smartmeet Agent Suite - 环境变量配置模板
# 复制此文件为 .env 并填写你的真实凭证
# ==============================================================================

# ==============================================================================
# 1. 🔴 【必须配置 / REQUIRED】 - 系统核心运行基础，不配置系统将报错/无法运行
# ==============================================================================

# === 统一大语言模型客户端 (Unified LLM Client) ===
# 必须：统一 API 密钥 (API Key)
# 示例如下:
#   - OpenAI: sk-proj-xxxxxxxx
#   - DeepSeek: sk-xxxxxxxx
#   - Cloudflare: 填写您的 Cloudflare API Token (如 clsf_xxxxxxxx)
LLM_API_KEY=your_api_key_here

# 建议：API 端点 URL (如果不配置，默认使用 OpenAI 官方默认端点 https://api.openai.com/v1)
# 示例如下:
#   - OpenAI: https://api.openai.com/v1
#   - DeepSeek: https://api.deepseek.com/v1
#   - Cloudflare: https://api.cloudflare.com/client/v4/accounts/{YOUR_CLOUDFLARE_ACCOUNT_ID}/ai/v1
#                 (注意：此处的大括号 {YOUR_CLOUDFLARE_ACCOUNT_ID} 须手动替换为您真实的 Cloudflare 账号 ID 字符串)
LLM_BASE_URL=https://api.openai.com/v1

# 建议：指定调用的模型名称 (默认使用 gpt-4o-mini)
# 示例如下:
#   - OpenAI: gpt-4o-mini 或 gpt-4o
#   - DeepSeek: deepseek-chat
#   - Cloudflare: @cf/meta/llama-3-8b-instruct
LLM_MODEL=gpt-4o-mini


# ==============================================================================
# 2. 🟡 【高度推荐 / RECOMMENDED】 - 开启完整本地音视频离线流水线所必需
# ==============================================================================

# === 本地多模态与语音转写引擎 (ASR / PyAnnote) ===
# HuggingFace Token (仅在 ASR_ENGINE 使用 whisper 且启用 PyAnnote 说话人分离声纹模型时必须配置)
# 注意：若 ASR_ENGINE 配置为 funasr，系统已集成免审批的本地 CAM++ 声纹模型，无需配置此 Token，保持为空即可。
# 可在 https://huggingface.co/settings/tokens 免费注册获取，并在 HuggingFace 上同意 Pyannote 开源协议
HF_TOKEN=hf_xxxxx

# 语音转写引擎偏好 (可选: auto, funasr, faster_whisper, sensevoice, openai, groq)
# - auto: 根据会议语言自动探测 (中文自动使用本地 funasr，非中文使用 faster_whisper)
# - funasr: 强制使用本地 FunASR (推荐低配 CPU 中文场景)
# - faster_whisper: 强制使用本地 Faster-Whisper
ASR_ENGINE=auto

# 本地 Whisper 模型大小 (仅在 ASR_ENGINE 使用 Whisper 时生效，可选: tiny/base/small/medium/large-v3)
WHISPER_MODEL_SIZE=large-v3
# 转写的目标语言 (zh 表示中文)
WHISPER_LANGUAGE=zh
# 运行硬件设备 (cuda 表示显卡加速, cpu 表示普通处理器运行，对 Whisper 和 FunASR 均生效)
WHISPER_DEVICE=cuda


# ==============================================================================
# 3. 🟢 【可选配置 / OPTIONAL】 - 外部接口、多端网关与第三方集成 (不配置将自动降级/无缝绕过)
# ==============================================================================

# === 系统与编码设置 ===
PYTHONIOENCODING=utf-8
LOG_LEVEL=INFO

# === 数据库与缓存 ===
# Redis 连接串（用于分布式任务队列 ARQ 与 Pub/Sub）
REDIS_URL=redis://localhost:6379/0

# === CORS 跨域配置 ===
# 允许的前端源地址，逗号分隔；开发环境默认放行本地地址，生产环境请替换为具体的前端域名
# 开发环境: http://localhost:3000,http://127.0.0.1:3000
# 生产环境: https://your-frontend.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# === ASR 专用配置（用于云端 OpenAI Whisper 或 Cloudflare ASR，不配置则默认使用本地 Whisper 引擎） ===
ASR_API_KEY=your_asr_key_here
ASR_BASE_URL=https://api.openai.com/v1
ASR_MODEL=@cf/openai/whisper

# === 外部音视频下载与代理 (YouTube / Bilibili) ===
# 网络代理 (国内访问 YouTube 等外国网站时使用)
NOTEKING_PROXY=socks5://127.0.0.1:7890
# 哔哩哔哩 HD 超清内容下载 Cookie (SESSDATA)
# 注意：如果不填或者保持为 "your_sessdata_here"，系统将自动以游客身份下载（最高支持480P，对于大部分录音分析场景已足够）。
# 若需要下载高清视频或突破风控限制，请填入真实的 SESSDATA。
BILIBILI_SESSDATA=your_sessdata_here

# === 飞书 (Lark) 协同闭环集成 ===
# 飞书自建应用凭证 (用于调用 OpenAPI 上传 PDF/思维导图报告)
FEISHU_APP_ID=your_feishu_app_id_here
# 飞书自建应用密钥
FEISHU_APP_SECRET=your_feishu_app_secret_here
# 接收会议资产报告的飞书群聊 ID / 聊天 ID
FEISHU_RECEIVE_ID=your_feishu_chat_id_here
# 飞书群聊自定义机器人 Webhook 链接 (仅用于推送图文会议纪要消息卡片，不支持发送 PDF 附件)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# === Jira Cloud 待办闭环集成 ===
# Jira 服务器地址 (例如: https://your-domain.atlassian.net)
JIRA_SERVER=https://your-domain.atlassian.net
# 你的 Jira 登录邮箱
JIRA_EMAIL=your_jira_email@example.com
# Jira API Token (可在 Atlassian 账号设置 -> 安全中生成)
JIRA_API_TOKEN=your_jira_api_token_here
# 同步待办与挂载附件的目标 Jira 项目键值
JIRA_PROJECT_KEY=MEET
