# ==============================================================================
# Smartmeet Agent Suite - 环境变量配置模板
# 复制此文件为 .env 并填写你的真实凭证
# ==============================================================================

# === 系统与编码设置 ===
PYTHONIOENCODING=utf-8
LOG_LEVEL=INFO

# === 服务端口与主机配置 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WEBSOCKET_PORT=8001

# === 数据库与缓存 ===
# 本地 PostgreSQL 与 Redis 连接（用于持久化和异步任务队列）
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartmeet
REDIS_URL=redis://localhost:6379/0

# === 统一 LLM 客户端配置 ===
# 统一 API 密钥与端点，适配 OpenAI, DeepSeek, MiniMax, Cloudflare Workers AI 等所有 OpenAI 兼容服务
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.cloudflare.com/client/v4/accounts/{your_cf_account_id}/ai/v1
LLM_MODEL=@cf/openai/gpt-oss-120b

# === ASR 专用配置（用于云端 OpenAI Whisper 或 Cloudflare ASR，不配置则默认使用本地 Whisper） ===
ASR_API_KEY=your_asr_key_here
ASR_BASE_URL=https://api.openai.com/v1
ASR_MODEL=@cf/openai/whisper

# === 本地多模态与语音转写引擎 (Whisper / PyAnnote) ===
# Whisper 模型大小 (tiny/base/small/medium/large-v3)
WHISPER_MODEL_SIZE=large-v3
# 转写的目标语言 (zh 表示中文)
WHISPER_LANGUAGE=zh
# 运行硬件设备 (cuda 表示显卡加速, cpu 表示普通处理器运行)
WHISPER_DEVICE=cuda

# HuggingFace Token (用于下载 PyAnnote 说话人分离声纹模型，必须配置)
# 可在 https://huggingface.co/settings/tokens 免费获取并同意 Pyannote 的开源协议
HF_TOKEN=hf_xxxxx

# === 外部音视频下载与代理 (YouTube / Bilibili) ===
# 网络代理 (国内访问 YouTube 等网站时使用)
NOTEKING_PROXY=socks5://127.0.0.1:7890
# 哔哩哔哩 HD 超清内容下载 Cookie (SESSDATA)
BILIBILI_SESSDATA=your_sessdata_here

# === 飞书 (Lark) 自助集成 ===
# 飞书应用凭证（用于自动创建飞书任务）
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
# 飞书群聊机器人 Webhook 链接（用于推送图文会议纪要卡片）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# === Jira Cloud 协同集成 ===
# Jira 服务器地址 (例如: https://your-domain.atlassian.net)
JIRA_SERVER=https://your-domain.atlassian.net
# 你的 Jira 登录邮箱
JIRA_EMAIL=your_jira_email@example.com
# Jira API Token (可在 Atlassian 账号设置中生成)
JIRA_API_TOKEN=your_jira_api_token_here
# 同步待办的目标 Jira 项目键值
JIRA_PROJECT_KEY=MEET
