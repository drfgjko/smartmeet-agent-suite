# ==============================================================================
# Smartmeet Frontend - 环境变量配置模板
# ==============================================================================

# 🔵 【纯静态演示模式 (Demo Mode)】
# 开启后前端将断开与后端的连接，从 public/demos 目录加载静态的演示数据。
# 适用于 Vercel/Netlify 纯静态部署。
# 本地开发或需要真实后端能力时，请将其删除或设置为 false。
NEXT_PUBLIC_DEMO_MODE=false
